{
  "projectSettings": {
    "installCommand": "npm install --prefix backend && npm install --prefix frontend",
    "buildCommand": "npm run build --prefix frontend",
    "devCommand": "concurrently \"npm run dev --prefix backend\" \"npm start --prefix frontend\""
  },
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "create-react-app"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "routes": [
    {
      "src": "^/_/backend/(.*)",
      "dest": "backend/$1"
    },
    {
      "src": "^/(?!_/backend).*",
      "dest": "frontend/index.html"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
