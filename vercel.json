{
  "buildCommand": "npm run build --prefix frontend && npm run build --prefix backend",
  "outputDirectory": "./frontend/build",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/backend/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    },
    {
      "src": "^/images/(.*)",
      "dest": "/backend/public/images/$1"
    },
    {
      "src": ".*",
      "dest": "/index.html"
    }
  ]
}
